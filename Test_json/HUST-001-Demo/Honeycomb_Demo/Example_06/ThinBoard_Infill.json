                      }
                  }
             },
        "10": {
            "Add_Lattice": {
                "la_name": ".//GenConformalMesh.mld",
                "size": [
                    50.0,
                    50.0,
                    50.0
                ],
                "thk": 8.00,
                "Rot": [
                    0.0,
                    0.0,
                    0.0
                ],
                "Trans": [
                    0.0,
                    0.0,
                    0.0
                ],
                "Inv": false,
                "Fill": true,
                "Cube_Request": {}
            }
        },
        
        "999": {
            "Export": {
                "outfile": ".//BoxMesh_ConformalLattice.stl"
            }
        }
    },
    "PostProcess": {
        "CombineMeshes": true,
        "RemovePartitionMeshFile": false,
        "RemoveIsolatedParts": true,
        "ExportLazPts": true
    }
