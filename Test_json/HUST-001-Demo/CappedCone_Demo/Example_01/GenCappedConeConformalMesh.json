                         }
                }
            }
        },
        "3":{
            "Define_Lattice":{
                "la_name":"GenCylindricalConformalMesh",
                "definition":{
                        "type": "ConformalLattice",
                        "definition": {
                          "meshfile": "CylindricalMesh",
                          "la_name" : "CustomLattice_Strut",
                          "la_domain": "Hex"
