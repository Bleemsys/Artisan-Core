                               [3, 2],
                               [2, 1],
                               [1, 6],
                               [0, 7],
                        
                               [3, 4],
                               [2, 5],
                               [7, 4],
                               [7, 6],
                               [6, 5],
                        
                               [4, 5],
                               [0, 5],
