                    0.0,
                    0.0
                ],
                "Inv": false,
                "Fill": false,
                "Cube_Request": {}
            }
        },
        "999": {
            "Export": {
                "outfile": ".//Test_results/ConeMesh_ConformalLattice.stl"
            }
        }
    },
    "PostProcess": {
        "CombineMeshes": true,
        "RemovePartitionMeshFile": false,
        "RemoveIsolatedParts": true,
        "ExportLazPts": true
